# Example environment variables for local/dev
AZURE_OPENAI_ENDPOINT=https://foundry-ai-mc-dev.cognitiveservices.azure.com/
AZURE_OPENAI_MODEL=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_KEY=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_SERVICE_ENDPOINT=https://as-ai-sitemc-dev.search.windows.net
DOCUMENT_SEARCH_INDEX_NAME=cv-doc-chunks

# Microsoft Foundry agent creation
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
FOUNDRY_SEARCH_API_URL=
FOUNDRY_SEARCHER_WRAPPER_URL=

# Chunking defaults (chars)
AZURE_SEARCH_CHUNK_SIZE=2000
AZURE_SEARCH_CHUNK_OVERLAP=200

# Storage
AzureWebJobsStorage=
STORAGE_CONTAINER_INCOMING=incoming-cv
STORAGE_CONTAINER_NORMALIZED_MARKDOWN=normalized-cv-md
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
